{
  "mcpServers": {
    "easyverein": {
      "command": "dotnet",
      "args": ["run", "--project", "src/MCP.EasyVerein.Server"],
      "env": {
        "EASYVEREIN_API_VERSION": "v2.0",
        "EASYVEREIN_API_KEY": "Bearer <your-easyverein-api-token-here>",
        "EASYVEREIN_API_URL": "https://easyverein.com/api"
      }
    }
  }
}
